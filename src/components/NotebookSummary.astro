---
/**
 * NotebookSummary — displays latest experiment findings from Supabase.
 * Fetches client-side on page load so data is always fresh (same as dashboard).
 */

interface Props {
	notebookLink?: string
	class?: string
}

const { notebookLink = '/analysis/', class: className } = Astro.props
---

<div id="notebook-summary" class={className || ''} data-notebook-link={notebookLink}>
	<div class="border border-dashed border-border rounded-lg p-6 text-muted-foreground text-sm text-center">
		Loading experiment summary...
	</div>
</div>

<script is:inline define:vars={{
	SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
	SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
}}>
(function() {
	const container = document.getElementById('notebook-summary')
	if (!container) return
	const notebookLink = container.dataset.notebookLink || '/analysis/'

	const STATUS = {
		significant: { color: 'text-green-600', bg: 'bg-green-50 dark:bg-green-950/30', label: 'Significant',
			icon: '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>' },
		not_significant: { color: 'text-amber-600', bg: 'bg-amber-50 dark:bg-amber-950/30', label: 'Not Significant',
			icon: '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>' },
		inconclusive: { color: 'text-gray-600', bg: 'bg-gray-50 dark:bg-gray-800/50', label: 'Inconclusive',
			icon: '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' },
		error: { color: 'text-red-600', bg: 'bg-red-50 dark:bg-red-950/30', label: 'Error',
			icon: '<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>' }
	}

	const TREND_UP = '<svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>'
	const TREND_DOWN = '<svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>'
	const WARN_ICON = '<svg class="h-4 w-4 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'
	const ARROW = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>'

	function deltaColor(dir) {
		if (dir === 'up') return 'text-green-600'
		if (dir === 'down') return 'text-red-600'
		return 'text-gray-500'
	}

	function deltaIcon(dir) {
		if (dir === 'up') return TREND_UP
		if (dir === 'down') return TREND_DOWN
		return ''
	}

	function formatTime(iso) {
		if (!iso) return ''
		return new Date(iso).toLocaleString('en-US', {
			year: 'numeric', month: 'short', day: 'numeric',
			hour: '2-digit', minute: '2-digit'
		})
	}

	async function load() {
		try {
			const res = await fetch(
				SUPABASE_URL + '/rest/v1/ab_simulator_summary?select=*&order=generated_at.desc&limit=1',
				{ headers: { apikey: SUPABASE_ANON_KEY, Authorization: 'Bearer ' + SUPABASE_ANON_KEY } }
			)
			if (!res.ok) throw new Error(res.status)
			const rows = await res.json()
			if (!rows.length) throw new Error('No data')
			render(rows[0])
		} catch (e) {
			container.innerHTML = '<div class="border border-dashed border-border rounded-lg p-4 text-muted-foreground text-sm">Error loading experiment summary</div>'
		}
	}

	function render(d) {
		const s = STATUS[d.status] || STATUS.error
		const warnCount = (d.warnings || []).length

		const metricsHtml = (d.metrics || []).map(function(m) {
			const dc = deltaColor(m.delta_direction)
			const di = deltaIcon(m.delta_direction)
			return '<div class="space-y-1">' +
				'<p class="text-xs text-muted-foreground uppercase tracking-wide">' + m.label + '</p>' +
				'<div class="flex items-baseline gap-2">' +
					'<span class="text-xl font-semibold text-foreground">' + m.value + '</span>' +
					(m.delta ? '<span class="flex items-center gap-0.5 text-sm ' + dc + '">' + di + m.delta + '</span>' : '') +
				'</div>' +
				(m.context ? '<p class="text-xs text-muted-foreground">' + m.context + '</p>' : '') +
			'</div>'
		}).join('')

		const warningsHtml = (d.warnings || []).map(function(w) {
			return '<div class="flex items-start gap-2 text-sm text-amber-700 dark:text-amber-400">' + WARN_ICON + '<span>' + w + '</span></div>'
		}).join('')

		container.innerHTML =
			'<div class="border border-border rounded-lg overflow-hidden">' +
				// Header
				'<div class="px-5 py-4 border-b border-border ' + s.bg + '">' +
					'<div class="flex items-center justify-between gap-4 flex-wrap">' +
						'<div class="flex items-center gap-3">' +
							'<span class="' + s.color + '">' + s.icon + '</span>' +
							'<div>' +
								'<h3 class="font-semibold text-foreground">A/B Test: Pineapple Finder Difficulty</h3>' +
								'<span class="text-sm"><span class="font-medium ' + s.color + '">' + s.label + '</span>' +
								(warnCount > 0 ? '<span class="text-amber-600 dark:text-amber-400"> — ' + warnCount + ' warning' + (warnCount > 1 ? 's' : '') + ' below</span>' : '<span class="text-muted-foreground"> — no warnings</span>') +
								'</span>' +
							'</div>' +
						'</div>' +
						'<div class="flex items-center gap-4">' +
							(d.generated_at ? '<span class="text-xs text-muted-foreground hidden sm:inline">Updated: ' + formatTime(d.generated_at) + '</span>' : '') +
							'<a href="' + notebookLink + '" class="inline-flex items-center gap-1.5 rounded-md bg-foreground px-3 py-1.5 text-sm font-medium text-background transition-colors hover:bg-foreground/90">View Notebook ' + ARROW + '</a>' +
						'</div>' +
					'</div>' +
				'</div>' +
				// Decision
				'<div class="px-5 py-4 bg-muted/30 border-b border-border"><p class="text-foreground"><span class="font-semibold">Decision:</span> ' + d.decision + '</p></div>' +
				// Metrics
				'<div class="px-5 py-4 grid grid-cols-2 md:grid-cols-4 gap-4">' + metricsHtml + '</div>' +
				// Warnings
				(warningsHtml ? '<div class="px-5 py-3 border-t border-border bg-amber-50/50 dark:bg-amber-950/20 space-y-1">' + warningsHtml + '</div>' : '') +
				// Methodology
				(d.methodology ? '<div class="px-5 py-2 border-t border-border bg-muted/10 text-xs text-muted-foreground"><span class="font-medium">Methodology:</span> ' + d.methodology + '</div>' : '') +
			'</div>'
	}

	load()
})()
</script>
