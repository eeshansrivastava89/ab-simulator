---
import Layout from '../layouts/Layout.astro'
import NotebookSummary from '../components/NotebookSummary.astro'
---

<Layout>
	<!-- Hero Value Prop - 3 Column + Your Assignment -->
	<div class='-mt-4 mb-6 overflow-hidden rounded-2xl border-2 border-border bg-gradient-to-br from-card via-card to-amber-50/50 shadow-lg'>
		<div class='grid divide-y md:grid-cols-3 md:divide-x md:divide-y-0 divide-border'>
			<!-- Col 1: You're in the experiment -->
			<div class='flex flex-col items-center gap-1.5 p-4 text-center sm:gap-2 sm:p-5'>
				<div class='flex items-center gap-2'>
					<div class='flex h-8 w-8 items-center justify-center rounded-xl bg-amber-100 text-lg sm:h-10 sm:w-10 sm:text-xl'>🎲</div>
					<div class='text-base font-bold text-foreground sm:text-lg'>You're in the Experiment</div>
				</div>
				<p class='text-xs text-muted-foreground sm:text-sm'>
					This is a real A/B test. You've been randomly assigned to <strong class='text-amber-600'>Variant A</strong> or <strong class='text-orange-600'>Variant B</strong>.
				</p>
			</div>
			<!-- Col 2: Play the game -->
			<div class='flex flex-col items-center gap-1.5 p-4 text-center sm:gap-2 sm:p-5'>
				<div class='flex items-center gap-2'>
					<div class='flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100 text-lg sm:h-10 sm:w-10 sm:text-xl'>🎮</div>
					<div class='text-base font-bold text-foreground sm:text-lg'>Play the Memory Game</div>
				</div>
				<p class='text-xs text-muted-foreground sm:text-sm'>
					Memorize pineapple locations, then find them all. Your completion time is tracked.
				</p>
			</div>
			<!-- Col 3: Watch results -->
			<div class='flex flex-col items-center gap-1.5 p-4 text-center sm:gap-2 sm:p-5'>
				<div class='flex items-center gap-2'>
					<div class='flex h-8 w-8 items-center justify-center rounded-xl bg-sky-100 text-lg sm:h-10 sm:w-10 sm:text-xl'>📊</div>
					<div class='text-base font-bold text-foreground sm:text-lg'>See Real-Time Results</div>
				</div>
				<p class='text-xs text-muted-foreground sm:text-sm'>
					Every game contributes real data. Live dashboard below, published analysis at <a href='https://eeshans.com/analysis?project=ab-simulator' class='whitespace-nowrap font-semibold text-sky-600 underline decoration-sky-300 underline-offset-2 hover:text-sky-700'>Analysis&nbsp;→</a>
				</p>
			</div>
		</div>
		<!-- Your Assignment Bar -->
		<div id='challenge-section' class='flex flex-wrap items-center justify-center gap-x-8 gap-y-3 border-t border-border bg-card px-6 py-4'>
			<div class='flex items-center gap-2'>
				<span class='text-sm font-medium text-muted-foreground'>Variant:</span>
				<span id='user-variant' class='rounded-lg bg-card px-3 py-1 font-mono text-sm font-bold shadow-sm'>Loading...</span>
			</div>
			<div class='flex items-center gap-2'>
				<span class='text-sm font-medium text-muted-foreground'>Username:</span>
				<span id='user-username' class='max-w-[180px] truncate rounded-lg bg-card px-3 py-1 font-mono text-sm shadow-sm'>Loading...</span>
			</div>
			<div class='flex items-center gap-2'>
				<span class='text-sm font-medium text-muted-foreground'>Find:</span>
				<span class='flex items-center gap-1 rounded-lg bg-card px-3 py-1 font-mono text-sm font-bold shadow-sm'>
					<span id='target-word-count'>0</span>
					<span>🍍</span>
				</span>
			</div>
		</div>
	</div>

	<!-- Puzzle Section -->
	<div id='puzzle-section' class='space-y-4 rounded-2xl border bg-card p-4'>
		<h3 class='text-lg font-semibold'>Memorize the pineapple locations, then find them all 🍍. <span class='text-amber-600'>7 seconds to memorize, 60 seconds to find.</span></h3>
		<p class='text-xs text-muted-foreground'>Found a bug? <a href='https://github.com/eeshansrivastava89/ab-simulator/issues/new' target='_blank' class='underline hover:text-foreground'>Report it on GitHub</a></p>

		<!-- Three-column layout: Grid (1/3) + Controls/Progress (1/3) + Stats (1/3) -->
		<div class='grid gap-6 md:grid-cols-2 xl:grid-cols-3'>
			<!-- LEFT: Letter Grid with countdown pill -->
			<div class='space-y-3'>
				<div id='memorize-pill' class='memorize-pill' data-state='idle'>
					<div class='flex items-center justify-between'>
						<span id='memorize-pill-text' class='text-sm font-medium text-muted-foreground'>Memorize Time</span>
						<div id='memorize-countdown' class='memorize-countdown' aria-live='polite'>7s</div>
					</div>
				</div>
				<div
					id='letter-grid'
					class='grid grid-cols-5 gap-2 rounded-2xl border-2 border-transparent p-1 transition-all duration-300'
				>
				</div>
			</div>

			<!-- CENTER: Controls + Pineapple Progress -->
			<div class='flex flex-col gap-4'>
				<div class='space-y-3 rounded-2xl border border-border/60 bg-muted/60 p-4 shadow-sm'>
					<div id='controls' class='flex flex-row gap-2'>
						<button
							id='start-button'
							class='flex-1 rounded-lg bg-primary px-3 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90'
							>Start</button
						>
						<button
							id='reset-button'
							class='hidden flex-1 rounded-lg bg-foreground px-3 py-2 text-sm font-medium text-background transition-colors hover:bg-foreground/90'
							>Stop</button
						>
						<button
							class='try-again-button hidden flex-1 rounded-lg bg-foreground px-3 py-2 text-sm font-medium text-background transition-colors hover:bg-foreground/90'
							>Try Again</button
						>
					</div>
					<div class='flex items-center justify-between rounded-xl bg-card px-4 py-3'>
						<div class='text-sm font-medium text-muted-foreground'>Time</div>
						<div id='timer' class='font-mono text-3xl font-bold tabular-nums tracking-tight'>00:60:00</div>
					</div>
				</div>
				<div class='pineapple-progress' aria-live='polite'>
					<div class='flex items-center justify-between'>
						<span class='text-xs font-bold uppercase tracking-widest text-muted-foreground'>Pineapple Tracker</span>
						<span class='font-mono text-sm font-semibold tabular-nums text-foreground'>
							<span id='pineapple-progress-found'>0</span>/<span id='pineapple-target'>0</span>
						</span>
					</div>
					<div class='pineapple-progress-track' id='pineapple-progress-track'>
						<div class='pineapple-progress-fill' id='pineapple-progress-fill'></div>
						<div class='pineapple-progress-slots' id='pineapple-progress-slots'></div>
					</div>
					<div id='pineapple-stats' class='pineapple-stats' aria-live='polite'>
						<div class='pineapple-stats-time'>
							<span class='label'>Time</span>
							<span id='pineapple-result-time' class='value'>00:00:00</span>
						</div>
						<div class='pineapple-stats-divider'></div>
						<div class='pineapple-stats-guesses'>
							<span class='label'>Guesses</span>
							<span id='pineapple-result-guesses' class='value'>0</span>
						</div>
					</div>
				</div>
			</div>

			<!-- RIGHT: Leaderboard (1/3) -->
			<div
				id='leaderboard-display'
				class='rounded-2xl border border-border/60 bg-muted/70 p-4 shadow-sm'
			>
				<div class='flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-muted-foreground'>
					<span class='text-lg'>🏆</span>
					<span>Top Players</span>
				</div>
				<div id='leaderboard-list' class='mt-3'></div>
			</div>
		</div>
	</div>

	<!-- Dashboard -->
	<div id='dashboard-section' class='space-y-6 rounded-lg border bg-card p-4'>
		<div class='flex items-center justify-between'>
			<div>
				<h3 class='mb-3 text-lg font-semibold'>📊 Live Dashboard</h3>
				<p class='text-sm text-muted-foreground'>Real-time descriptive stats. But don't conclude experiment using this data. <br />Check the detailed statistical analysis at <a href='https://eeshans.com/analysis?project=ab-simulator' class='whitespace-nowrap font-semibold text-sky-600 underline decoration-sky-300 underline-offset-2 hover:text-sky-700'>Analysis&nbsp;→</a></p>
			</div>
			<div class='flex items-center gap-3'>
				<button
					onclick='window.refreshDashboard()'
					class='rounded border border-border px-2 py-1 text-xs transition-colors hover:bg-muted'
					title='Refresh dashboard data'
				>
					🔄 Refresh
				</button>
				<div id='update-indicator' class='text-xs text-muted-foreground'>
					<span id='last-updated'>Loading...</span>
				</div>
			</div>
		</div>

		<!-- Comparison Card -->
		<div class='rounded-xl border bg-card p-6'>
			<div class='grid grid-cols-1 gap-4 sm:grid-cols-3 sm:gap-6'>
				<!-- Variant A -->
				<div class='space-y-3'>
					<div class='flex items-center gap-2'>
						<div class='flex h-6 w-6 items-center justify-center rounded bg-[#f9e9cc] text-xs font-bold text-black'>A</div>
						<div class='text-sm font-semibold'>Control (4 pineapples)</div>
					</div>
					<div>
						<div class='text-xs text-muted-foreground'>Total Completions</div>
						<div id='variant-a-count' class='text-2xl font-bold'>--</div>
					</div>
					<div>
						<div class='text-xs text-muted-foreground'>Avg Completion Time</div>
						<div id='variant-a-time' class='font-mono text-2xl font-bold'>--</div>
					</div>
				</div>

				<!-- Variant B -->
				<div class='space-y-3'>
					<div class='flex items-center gap-2'>
						<div class='flex h-6 w-6 items-center justify-center rounded bg-[#f5a656] text-xs font-bold text-black'>B</div>
						<div class='text-sm font-semibold'>Treatment (5 pineapples)</div>
					</div>
					<div>
						<div class='text-xs text-muted-foreground'>Total Completions</div>
						<div id='variant-b-count' class='text-2xl font-bold'>--</div>
					</div>
					<div>
						<div class='text-xs text-muted-foreground'>Avg Completion Time</div>
						<div id='variant-b-time' class='font-mono text-2xl font-bold'>--</div>
					</div>
				</div>

				<!-- Comparison -->
				<div class='space-y-3'>
					<div class='flex items-center gap-2'>
						<div class='text-xl'>⚖️</div>
						<div class='text-sm font-semibold'>Comparison</div>
					</div>
					<div>
						<div class='text-xs text-muted-foreground'>Time Difference</div>
						<div id='comparison-diff' class='font-mono text-2xl font-bold text-muted-foreground'>--%</div>
					</div>
					<div id='comparison-status-box' class='rounded-lg bg-muted p-3'>
						<div id='comparison-status' class='text-sm font-medium'>--</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Funnel Chart -->
		<div class='rounded-lg border bg-card p-4'>
			<div id='funnel-chart' class='h-[320px] w-full'></div>
		</div>

		<!-- Charts Grid: Avg Time + Distribution -->
		<div class='grid grid-cols-1 gap-6 lg:grid-cols-2'>
			<div class='rounded-lg border bg-card p-4'>
				<div id='avg-time-chart' class='h-[320px] w-full'></div>
			</div>
			<div class='rounded-lg border bg-card p-4'>
				<div id='distribution-chart' class='h-[320px] w-full'></div>
			</div>
		</div>

		<!-- Recent Completions Table -->
		<div class='rounded-lg border bg-card p-4'>
			<h3 class='mb-4 text-lg font-semibold'>Recent Completions</h3>
			<div id='completions-table'></div>
		</div>

		<!-- Global Completions Map -->
		<div class='rounded-lg border bg-card p-4'>
			<div class='mb-4 flex flex-wrap items-center justify-between gap-2'>
				<div class='flex items-center gap-3'>
					<h3 class='text-lg font-semibold'>🌍 Global Completions Map</h3>
					<span class='hidden sm:inline text-xs text-muted-foreground'>Scroll to zoom • Click markers for details</span>
				</div>
				<div class='flex items-center gap-2 sm:gap-4 text-sm'>
					<label id='follow-toggle' class='group flex cursor-pointer items-center gap-2'>
						<span class='hidden sm:inline text-xs font-medium text-muted-foreground'>Follow live</span>
						<div class='relative'>
							<input type='checkbox' id='follow-checkbox' class='peer sr-only' />
							<div class='h-5 w-9 rounded-full bg-muted transition-colors peer-checked:bg-emerald-500'></div>
							<div class='absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-card shadow transition-transform peer-checked:translate-x-4'></div>
						</div>
					</label>
					<span class='flex items-center gap-1.5'>
						<span class='inline-block h-3 w-3 rounded-full bg-[#F7CA45] ring-1 ring-amber-500'></span>
						<span class='hidden sm:inline text-muted-foreground'>Variant A</span>
					</span>
					<span class='flex items-center gap-1.5'>
						<span class='inline-block h-3 w-3 rounded-full bg-[#4572F7] ring-1 ring-blue-600'></span>
						<span class='hidden sm:inline text-muted-foreground'>Variant B</span>
					</span>
				</div>
			</div>
			<div id='geo-map' class='h-[450px] w-full cursor-pointer rounded-lg'></div>
		</div>
	</div>

	<!-- Understand It -->
	<div class="space-y-4">
		<h2 class="flex items-center gap-2 text-2xl font-bold">
			<span>📊</span> Understand it
		</h2>
		<NotebookSummary notebookId="ab-test-analysis" />
	</div>

	<!-- External libs -->
	<script src='https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js' is:inline></script>
	<link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css' />
	<script src='https://unpkg.com/leaflet@1.9.4/dist/leaflet.js' is:inline></script>

	<!-- Game JS -->
	<script src='/js/utils.js' is:inline></script>
	<script src='/js/puzzle-config.js' is:inline></script>

	<!-- Inject Supabase config -->
	<script
		is:inline
		define:vars={{
			SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
			SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
		}}
	>
		window.__SUPABASE_URL__ = SUPABASE_URL
		window.__SUPABASE_ANON_KEY__ = SUPABASE_ANON_KEY
	</script>

	<script src='/js/ab-sim/supabase-api.js' is:inline></script>
	<script src='/js/ab-sim/personal-best.js' is:inline></script>
	<script src='/js/ab-sim/leaderboard-ui.js' is:inline></script>
	<script src='/js/ab-sim/analytics.js' is:inline></script>
	<script src='/js/ab-sim/core.js' is:inline></script>
	<script src='/js/ab-sim/dashboard.js' is:inline></script>
</Layout>

<script>
	import { uniqueNamesGenerator, adjectives, animals } from 'unique-names-generator'

	;(window as any).generateRandomUsername = function () {
		return uniqueNamesGenerator({
			dictionaries: [adjectives, animals],
			separator: ' ',
			style: 'capital',
			length: 2
		})
	}
</script>
