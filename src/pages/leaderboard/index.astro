---
import Layout from '../../layouts/Layout.astro'

const title = 'Global Leaderboard'
const description = 'Cross-variant hall of fame for the A/B Testing Memory Game. Every pineapple hunter, ranked.'
---

<Layout title={title} description={description}>
	<div class="leaderboard-page space-y-8">
	<!-- Page Header -->
	<div class="text-center space-y-2">
		<h1 class="text-3xl sm:text-4xl font-bold">🏆 Global Leaderboard</h1>
		<p class="text-sm sm:text-base text-muted-foreground">
			Every pineapple hunter, ranked. Cross-variant hall of fame.
		</p>
	</div>

	<!-- Achievements -->
	<div class="space-y-5 rounded-2xl border bg-card px-6 py-5 shadow-sm" style="border-color:var(--border)">
		<div class="flex items-center gap-2 flex-wrap">
			<span class="text-lg">🎖️</span>
			<h2 class="text-xl font-bold">Your Achievements</h2>
			<span class="text-lg text-muted-foreground">|</span>
			<span class="text-xl italic text-muted-foreground">for <span id="badge-username-value" class="text-foreground">No player selected</span></span>
			<span class="text-lg text-muted-foreground">|</span>
			<span id="badge-earned-count" class="text-xl italic text-muted-foreground">0 of 6 earned</span>
			<a
				id="badge-cta"
				href="/"
				class="ml-auto hidden items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition hover:opacity-90"
			>
				Play your first game
			</a>
		</div>
		<div class="flex flex-wrap gap-2.5 pt-1" id="badge-list">
			<span class="badge locked" data-badge-key="first_game" data-tooltip="Awarded for completing your first game." tabindex="0">🍍 First Pineapple</span>
			<span class="badge locked" data-badge-key="speed_demon" data-tooltip="Awarded for an elite best time." tabindex="0">⚡ Speed Demon</span>
			<span class="badge locked" data-badge-key="top10" data-tooltip="Awarded for placing in the global top 10 by best time." tabindex="0">🥇 Top 10</span>
			<span class="badge locked" data-badge-key="marathoner" data-tooltip="Awarded after 10 completed games." tabindex="0">🏃 Marathoner 10+ games</span>
			<span class="badge locked" data-badge-key="contributor" data-tooltip="Awarded after 50 completed games." tabindex="0">🏅 Ultra-Marathoner 50+ games</span>
		</div>
	</div>

	<!-- Full Leaderboard -->
	<div class="space-y-4">
		<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
			<div class="flex items-center gap-2">
				<span class="text-lg">📋</span>
				<h2 class="text-xl font-bold">Full Leaderboard</h2>
			</div>
			<div class="flex items-center gap-2 flex-wrap">
				<div class="relative">
					<input type="text" id="lb-search" placeholder="Search player…"
						class="w-40 sm:w-56 rounded-lg border px-3 py-1.5 text-sm outline-none focus:ring-2 focus:ring-ring bg-card text-foreground"
						style="border-color:var(--border)">
				</div>
				<div class="flex items-center gap-1" id="variant-filters">
					<button class="filter-btn active" data-variant="">All</button>
					<button class="filter-btn" data-variant="A">A</button>
					<button class="filter-btn" data-variant="B">B</button>
				</div>
				<select id="lb-sort"
					class="rounded-lg border px-2 py-1.5 text-sm outline-none bg-card text-foreground"
					style="border-color:var(--border)">
					<option value="best_time">Best Time</option>
					<option value="most_games">Most Completions</option>
					<option value="avg_time">Avg Time</option>
				</select>
			</div>
		</div>

		<div class="rounded-2xl border overflow-hidden bg-card" style="border-color:var(--border)">
			<div class="overflow-x-auto max-h-[600px] overflow-y-auto">
				<table class="w-full lb-table" id="leaderboard-table">
					<thead>
						<tr>
							<th class="text-center w-12">#</th>
							<th>Player</th>
							<th class="text-center">V</th>
							<th class="text-right">Best</th>
							<th class="text-right">Avg</th>
							<th class="text-center">Games</th>
							<th class="text-right">Avg Guesses</th>
							<th>Location</th>
							<th class="text-center">Badges</th>
						</tr>
					</thead>
					<tbody id="leaderboard-body">
						<!-- Populated by JS -->
					</tbody>
				</table>
			</div>
			<div class="flex items-center justify-between px-4 py-3 border-t" style="border-color:var(--border)">
				<span class="text-[11px] text-muted-foreground" id="lb-pagination-info">Loading…</span>
				<div class="flex items-center gap-1" id="lb-pagination">
					<!-- Populated by JS -->
				</div>
			</div>
		</div>
	</div>

	<!-- Hero Stats Cards -->
	<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4" id="hero-stats">
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">⚡</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Fastest Time</div>
			<div class="font-mono text-xl font-bold text-green-600 dark:text-green-400" data-field="fastest_time">--</div>
			<div class="text-[11px] truncate text-muted-foreground" data-field="fastest_player">--</div>
		</div>
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">🎮</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Most Games</div>
			<div class="font-mono text-xl font-bold text-foreground" data-field="most_games">--</div>
			<div class="text-[11px] truncate text-muted-foreground" data-field="most_games_player">--</div>
		</div>
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">🏙️</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Cities</div>
			<div class="font-mono text-xl font-bold text-blue-600 dark:text-blue-400" data-field="cities">--</div>
			<div class="text-[11px] truncate text-muted-foreground">worldwide</div>
		</div>
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">🌍</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Countries</div>
			<div class="font-mono text-xl font-bold text-blue-600 dark:text-blue-400" data-field="countries">--</div>
			<div class="text-[11px] truncate text-muted-foreground">global</div>
		</div>
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">📍</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Top City</div>
			<div class="font-mono text-lg font-bold truncate text-foreground" data-field="top_city_name">--</div>
			<div class="text-[11px] truncate text-muted-foreground" data-field="top_city_count">--</div>
		</div>
		<div class="stat-card text-center space-y-1">
			<div class="text-2xl">🔥</div>
			<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Total Games</div>
			<div class="font-mono text-xl font-bold text-red-600 dark:text-red-400" data-field="total_games">--</div>
			<div class="text-[11px] truncate text-muted-foreground">and counting…</div>
		</div>
	</div>

	<!-- Charts Row -->
	<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
		<div class="stat-card">
			<div class="flex items-center justify-between mb-2">
				<div class="text-[10px] font-bold uppercase tracking-widest text-muted">Completion Time Distribution</div>
				<span class="text-[11px] font-mono text-muted-foreground" id="dist-n">n=--</span>
			</div>
			<div id="dist-chart" class="mini-chart"></div>
			<div class="flex items-center justify-center gap-4 mt-2 text-[11px]">
				<span class="flex items-center gap-1.5">
					<span class="inline-block w-3 h-0.5 rounded-full" style="background:#F7CA45"></span>
					A
				</span>
				<span class="flex items-center gap-1.5">
					<span class="inline-block w-3 h-0.5 rounded-full" style="background:#4572F7"></span>
					B
				</span>
			</div>
			<div class="flex justify-between mt-1 text-[10px] font-mono text-muted-foreground">
				<span id="dist-p50">P50: --</span>
				<span id="dist-p90">P90: --</span>
				<span id="dist-p99">P99: --</span>
			</div>
		</div>
		<div class="stat-card">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-2 text-muted">Peak Activity (Pacific Hour)</div>
			<div id="hour-chart" class="mini-chart"></div>
			<div class="text-center mt-1">
				<span class="font-mono text-base font-bold text-foreground" id="peak-hour">--:00 UTC</span>
				<span class="text-[11px] block text-muted-foreground" id="peak-count">-- completions</span>
			</div>
		</div>
		<div class="stat-card">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-2 text-muted">Variant Split</div>
			<div id="variant-chart" class="mini-chart"></div>
			<div class="flex justify-center gap-6 mt-1 text-[11px]">
				<span class="flex items-center gap-1.5">
					<span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#F7CA45"></span>
					<span id="split-a">A: --%</span>
				</span>
				<span class="flex items-center gap-1.5">
					<span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#4572F7"></span>
					<span id="split-b">B: --%</span>
				</span>
			</div>
		</div>
	</div>

	<!-- Mini Stats Row -->
	<div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="mini-stats">
		<div class="rounded-xl border px-4 py-3 text-center bg-card" style="border-color:var(--border)">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-1 text-muted">Avg Guesses</div>
			<div class="font-mono text-lg font-bold" data-field="avg_guesses">--</div>
			<div class="text-[10px] text-muted-foreground">per completion</div>
		</div>
		<div class="rounded-xl border px-4 py-3 text-center bg-card" style="border-color:var(--border)">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-1 text-muted">Most Improved</div>
			<div class="font-mono text-lg font-bold" data-field="most_improved_delta">--</div>
			<div class="text-[10px] truncate text-muted-foreground" data-field="most_improved_player">--</div>
		</div>
		<div class="rounded-xl border px-4 py-3 text-center bg-card" style="border-color:var(--border)">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-1 text-muted">Completion Rate</div>
			<div class="font-mono text-lg font-bold" data-field="completion_rate">--%</div>
			<div class="text-[10px] text-muted-foreground">finish before timeout</div>
		</div>
		<div class="rounded-xl border px-4 py-3 text-center bg-card" style="border-color:var(--border)">
			<div class="text-[10px] font-bold uppercase tracking-widest mb-1 text-muted">Repeat Rate</div>
			<div class="font-mono text-lg font-bold" data-field="repeat_rate">--%</div>
			<div class="text-[10px] text-muted-foreground">play 2+ times</div>
		</div>
	</div>

	<!-- Geo Map -->
	<div class="space-y-3">
		<div class="flex items-center gap-2">
			<span class="text-lg">🗺️</span>
			<h2 class="text-xl font-bold">Where Players Come From</h2>
		</div>
		<div class="rounded-2xl border overflow-hidden bg-card" style="border-color:var(--border)">
			<div id="geo-map" style="height:360px; width:100%;"></div>
		</div>
	</div>
	</div>
</Layout>

<!-- External libs (same as homepage) -->
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js" is:inline></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>

<!-- Inject Supabase config -->
<script
	is:inline
	define:vars={{
		SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
		SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
	}}
>
	window.__SUPABASE_URL__ = SUPABASE_URL
	window.__SUPABASE_ANON_KEY__ = SUPABASE_ANON_KEY
</script>

<script src="/js/ab-sim/supabase-api.js" is:inline></script>
<script src="/js/ab-sim/analytics.js" is:inline></script>
<script src="/js/ab-sim/leaderboard-page.js" is:inline></script>

<style>
	.stat-card {
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 20px;
		box-shadow: var(--shadow);
		transition: all 0.2s ease;
	}
	.stat-card:hover {
		box-shadow: var(--shadow-hover);
		transform: translateY(-2px);
	}
	.badge {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 6px 12px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 600;
		border: 1px solid var(--border);
		background: var(--card-raised);
		transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
		cursor: default;
	}
	.badge:hover { transform: scale(1.05); }
	.badge:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}
	.badge::before {
		content: '';
		position: absolute;
		left: 50%;
		bottom: calc(100% + 2px);
		transform: translateX(-50%) translateY(4px) rotate(45deg);
		width: 10px;
		height: 10px;
		background: rgb(42 33 27 / 1);
		opacity: 0;
		mix-blend-mode: normal;
		pointer-events: none;
		transition: opacity 0.16s ease, transform 0.16s ease;
		z-index: 20;
	}
	.badge::after {
		content: attr(data-tooltip);
		position: absolute;
		left: 50%;
		bottom: calc(100% + 10px);
		transform: translateX(-50%) translateY(4px);
		min-width: 180px;
		max-width: 240px;
		padding: 8px 10px;
		border-radius: 10px;
		background: rgb(42 33 27 / 1);
		color: #f8f3eb;
		font-size: 11px;
		font-weight: 500;
		line-height: 1.35;
		text-align: center;
		box-shadow: 0 10px 30px rgba(27, 19, 13, 0.18);
		opacity: 0;
		mix-blend-mode: normal;
		backdrop-filter: none;
		pointer-events: none;
		transition: opacity 0.16s ease, transform 0.16s ease;
		z-index: 21;
	}
	.badge:hover::before,
	.badge:hover::after,
	.badge:focus-visible::before,
	.badge:focus-visible::after {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}
	.badge:hover::before,
	.badge:focus-visible::before {
		transform: translateX(-50%) translateY(0) rotate(45deg);
	}
	.badge.earned {
		border-width: 2px;
		border-color: color-mix(in srgb, var(--amber) 72%, #4b3424 28%);
		background: linear-gradient(180deg, rgba(217, 119, 6, 0.14), rgba(217, 119, 6, 0.08));
		color: color-mix(in srgb, var(--amber) 48%, #3c3226 52%);
		box-shadow: 0 4px 14px rgba(217, 119, 6, 0.12);
		transform: translateY(-1px);
	}
	.badge.locked {
		border-style: dashed;
		background: color-mix(in srgb, var(--card-raised) 84%, white 16%);
		color: color-mix(in srgb, var(--muted-foreground) 82%, transparent 18%);
		opacity: 0.82;
		box-shadow: none;
	}
	[data-theme='dark'] .badge.earned {
		border-color: rgba(251, 191, 36, 0.68);
		background: linear-gradient(180deg, rgba(251, 191, 36, 0.22), rgba(251, 191, 36, 0.12));
		color: #fef3c7;
		box-shadow: 0 4px 16px rgba(251, 191, 36, 0.12);
	}
	[data-theme='dark'] .badge.locked {
		background: color-mix(in srgb, var(--card-raised) 88%, transparent 12%);
		color: color-mix(in srgb, var(--muted-foreground) 88%, transparent 12%);
	}
	[data-theme='dark'] .badge::before,
	[data-theme='dark'] .badge::after {
		background: #f4ede3;
		color: #2a211b;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
	}
	.mini-chart {
		height: 100px;
		width: 100%;
	}
</style>
